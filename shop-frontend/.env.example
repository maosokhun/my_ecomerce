# Stripe — publishable key (pk_test_… / pk_live_…) must match the mode of STRIPE_SECRET_KEY on the backend.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Browser / client API base (set in production to your public API URL)
# Example: https://your-api.onrender.com/api
# NEXT_PUBLIC_API_URL=

# Where Next.js proxies /api (must match at build time on hosts like Render)
# Dev default: http://127.0.0.1:5000
# BACKEND_PROXY_TARGET=http://127.0.0.1:5000

# Server-side fetch (RSC) when NEXT_PUBLIC_API_URL is unset
# INTERNAL_API_URL=http://127.0.0.1:5000/api
