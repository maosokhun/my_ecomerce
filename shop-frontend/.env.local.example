# Sign in with Google (GIS). Create OAuth "Web client" in Google Cloud Console; use same Client ID on Vercel + Render.
# NEXT_PUBLIC_GOOGLE_CLIENT_ID=123456789-xxxx.apps.googleusercontent.com

# Leave unset for dev: browser uses /api (Next.js proxies to Express). Required for LAN IP (192.168.x.x:3000).
# NEXT_PUBLIC_API_URL=http://localhost:5000/api
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
BACKEND_PROXY_TARGET=http://127.0.0.1:5000
INTERNAL_API_URL=http://127.0.0.1:5000/api
